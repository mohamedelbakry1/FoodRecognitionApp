							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@gmail.com\",\n    \"otp\": \"123456\",\n    \"password\": \"NewP@ssw0rd\",\n    \"confirmPassword\": \"NewP@ssw0rd\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/Auth/resetpassword",
							"host": ["{{baseUrl}}"],
							"path": ["api", "Auth", "resetpassword"]
						}
					}
